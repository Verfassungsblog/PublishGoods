<h1>Import</h1>

<div id="wizard-start" class="wizard-card">
    <div class="d-flex mt-5" style="justify-content: space-evenly;">
        <div class="import-card" id="wizard-wp-btn">
            <img style="width: 75px; height: fit-content" src="/assets/import_wizard/wordpress.png" alt="WordPress">
            <b>WordPress</b>
        </div>
        <div class="import-card" id="wizard-pandoc-btn">
            <img style="height: 50px;" src="/assets/import_wizard/pandoc_1.png" alt="Pandoc">
            <img style="height: 50px;" src="/assets/import_wizard/pandoc_2.png" alt="Pandoc">
            <img style="height: 50px;" src="/assets/import_wizard/pandoc_3.png" alt="Pandoc">
            <b>Pandoc</b>
        </div>
    </div>
</div>

<div id="wizard-pandoc-1" class="hide">
    <p>Settings:</p>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="wizard-pandoc-settings-convert-to-endnotes">
        <label class="form-check-label" for="wizard-pandoc-settings-convert-to-endnotes">
            Convert Footnotes to Endnotes
        </label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="wizard-pandoc-settings-shift-levels-up">
        <label class="form-check-label" for="wizard-pandoc-settings-shift-levels-up">
            Shift Headings up by one level
        </label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="wizard-pandoc-settings-convert-links">
        <label class="form-check-label" for="wizard-pandoc-settings-convert-links">
            Convert Links to Citations
        </label>
    </div>
    <p>Please supply one file per Section.</p>
    <input type="file" class="form-control" id="wizard-pandoc-upload-input" multiple/>
    <p class="mt-2">Optional bibliography</p>
    <input type="file" class="form-control" id="wizard-pandoc-upload-bib-input"/>
    <button class="btn btn-primary mt-2 float-end" id="wizard-pandoc-upload-btn">Upload</button>
</div>

<div id="wizard-progress" class="hide">
    <p>Import Progress:</p>
    <progress id="wizard-upload-progress" value="0" max="100"></progress>
    <p class="mt-2">Status: <span id="wizard-upload-progress-status"></span></p>
</div>

<div id="wizard-wordpress-1" class="hide">
    <div class="d-flex mt-5" style="justify-content: space-evenly;">
        <div class="import-card" id="wizard-wp-links-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="75" height="75" fill="currentColor" class="bi bi-link" viewBox="0 0 16 16">
                <path d="M6.354 5.5H4a3 3 0 0 0 0 6h3a3 3 0 0 0 2.83-4H9q-.13 0-.25.031A2 2 0 0 1 7 10.5H4a2 2 0 1 1 0-4h1.535c.218-.376.495-.714.82-1z"/>
                <path d="M9 5.5a3 3 0 0 0-2.83 4h1.098A2 2 0 0 1 9 6.5h3a2 2 0 1 1 0 4h-1.535a4 4 0 0 1-.82 1H12a3 3 0 1 0 0-6z"/>
            </svg>
            <b>Import by Links</b>
        </div>
        <div class="import-card" id="wizard-wp-filter-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="75" height="75" fill="currentColor" class="bi bi-funnel" viewBox="0 0 16 16">
                <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5zm1 .5v1.308l4.372 4.858A.5.5 0 0 1 7 8.5v5.306l2-.666V8.5a.5.5 0 0 1 .128-.334L13.5 3.308V2z"/>
            </svg>
            <b>Filter Posts</b>
        </div>
    </div>
</div>

<div id="wizard-wordpress-by-filter-1" class="hide">
    <label for="wizard-wordpress-host">Wordpress Host URL</label>
    <input type="text" class="form-control" id="wizard-wordpress-host" placeholder="example.com">
    <button class="btn btn-primary float-end mt-2" id="wizard-wordpress-host-next">Next</button>
</div>

<div id="wizard-wordpress-by-filter-2" class="hide">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
    <p>Loading Categories</p>
</div>

<div id="wizard-wordpress-by-filter-3" class="hide"></div>

<div id="wizard-wordpress-settings" class="hide">
    <p>Import Settings:</p>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="wizard-wordpress-settings-import-authors" checked>
        <label class="form-check-label" for="wizard-wordpress-settings-import-authors">
            Import author names from Wordpress
        </label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="wizard-wordpress-settings-convert-to-endnotes">
        <label class="form-check-label" for="wizard-wordpress-settings-convert-to-endnotes">
            Convert Footnotes to Endnotes
        </label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="wizard-wordpress-settings-shift-levels-up">
        <label class="form-check-label" for="wizard-wordpress-settings-shift-levels-up">
            Shift Headings up by one level
        </label>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="wizard-wordpress-settings-convert-links">
        <label class="form-check-label" for="wizard-wordpress-settings-convert-links">
            Convert Links to Citations
        </label>
    </div>
    <button class="btn btn-primary mt-2 float-end" id="wizard-wordpress-start-import-btn">Start Import</button>
</div>

<div id="wizard-wordpress-by-links" class="hide">
    <label for="wizard-wordpress-settings-links">Wordpress Post Links to import (one per line):</label>
    <textarea id="wizard-wordpress-settings-links" class="form-control"></textarea>
    <button class="form-control btn btn-primary float-end mt-2" style="width: auto;" id="wizard-wordpress-by-links-next">Next</button>
</div>
