<div class="export_step_weasyprint export_step card mt-1" data-export-step-id="{{id}}" data-export-step-type="weasyprint">
    <div class="card-header d-flex justify-content-between">[Weasyprint Export Step] {{name}} <div class="d-flex">    <button class="btn btn-xsm-square justify-content-center align-items-center d-flex export_step_delete_btn"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="red" class="bi bi-trash3" viewBox="0 0 16 16">
        <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5"></path>
    </svg></button>
        {{#if id}}
        <button class="btn btn-xsm-square justify-content-center align-items-center d-flex export_step_move_up_btn">
            <svg xmlns="http://www.w3.org/2000/svg" height="36" viewBox="0 -960 960 960" width="36"><path d="M480-528 296-344l-56-56 240-240 240 240-56 56-184-184Z"></path></svg>
        </button>
        <button class="btn btn-xsm-square justify-content-center align-items-center d-flex export_step_move_down_btn">
            <svg xmlns="http://www.w3.org/2000/svg" height="36" viewBox="0 -960 960 960" width="36"><path d="M480-344 240-584l56-56 184 184 184-184 56 56-240 240Z"></path></svg>
        </button>
        {{/if}}
    </div>

    </div>
    <div class="card-body">
        <label for="{{id}}_name">Name*</label>
        <input id="{{id}}_name" class="form-control export_step_weasyprint_name autosave" type="text" placeholder="e.g. Preview PDF" value="{{name}}">
        <label for="{{id}}_input_file">Input File Path*</label>
        <input id="{{id}}_input_file" class="form-control export_step_weasyprint_input_file autosave" type="text" placeholder="e.g. main.html" value="{{data.Weasyprint.input_file}}">
        <label for="{{id}}_output_file">Output File*</label>
        <input id="{{id}}_output_file" class="form-control export_step_weasyprint_output_file autosave" type="text" placeholder="e.g. main.pdf" value="{{data.Weasyprint.output_file}}">
        <label for="{{id}}_pdf_variant">PDF Variant</label>
        <select id="{{id}}_pdf_variant" class="form-select export_step_weasyprint_pdf_variant autosave">
            <option value="PDF" {{#is data.Weasyprint.pdf_variant "PDF"}}selected{{/is}}>PDF</option>
            <option value="PDFA1B" {{#is data.Weasyprint.pdf_variant "PDFA1B"}}selected{{/is}}>PDF/A-1b</option>
            <option value="PDFA2B" {{#is data.Weasyprint.pdf_variant "PDFA2B"}}selected{{/is}}>PDF/A-2b</option>
            <option value="PDFA3B" {{#is data.Weasyprint.pdf_variant "PDFA3B"}}selected{{/is}}>PDF/A-3b</option>
            <option value="PDFA4B" {{#is data.Weasyprint.pdf_variant "PDFA4B"}}selected{{/is}}>PDF/A-4b</option>
            <option value="PDFA2U" {{#is data.Weasyprint.pdf_variant "PDFA2U"}}selected{{/is}}>PDF/A-2u</option>
            <option value="PDFA3U" {{#is data.Weasyprint.pdf_variant "PDFA3U"}}selected{{/is}}>PDF/A-3u</option>
            <option value="PDFA4U" {{#is data.Weasyprint.pdf_variant "PDFA4U"}}selected{{/is}}>PDF/A-4u</option>
            <option value="PDFUA1" {{#is data.Weasyprint.pdf_variant "PDFUA1"}}selected{{/is}}>PDF/UA-1</option>
            <option value="DEBUG" {{#is data.Weasyprint.pdf_variant "DEBUG"}}selected{{/is}}>debug</option>
        </select>
    </div>
</div>