<div class="editor_bibliography_folder_editor">
    <div class="editor_section_view_collapsed_metadata">
        <div class="editor_section_view_collapsed_metadata_inner">
            <h1>{{entry.BibFolder.name}}</h1>
            <h2>Folder</h2>
        </div>
    </div>

    <div class="editor_section_view_metadata">
        <div class="form-group">
            <label>Folder Name</label>
            <input type="text" class="form-control form-control-sm bib-quickchange" data-path="BibFolder.name" value="{{entry.BibFolder.name}}">
        </div>

        <div class="form-group mt-4">
            <label>Danger Zone</label><br>
            <button class="btn btn-sm btn-danger" id="bib_entry_delete">Delete Folder</button>
        </div>
    </div>
</div>
