                <option value="vi-VN">Vietnamese (Vietnam) (vi-VN)</option>
                <option value="cy-GB">Welsh (United Kingdom) (cy-GB)</option>
                <option value="wo-SN">Wolof (Senegal) (wo-SN)</option>
                <option value="xh-ZA">Xhosa (South Africa) (xh-ZA)</option>
                <option value="yi-001">Yiddish (World) (yi-001)</option>
                <option value="yo-NG">Yoruba (Nigeria) (yo-NG)</option>
                <option value="zu-ZA">Zulu (South Africa) (zu-ZA)</option>
                <option value="tzm-Arab-MA">Central Atlas Tamazight (Arabic, Morocco) (tzm-Arab-MA)</option>
                <option value="tzm-Latn-DZ">Tamazight (Latin, Algeria) (tzm-Latn-DZ)</option>
                <option value="ii-CN">Yi (People's Republic of China) (ii-CN)</option>
            </select>
        </div>
    </div>
    <div>
        <label for="project_metadata_license">License</label>
        <div class="form-group-inline">
            <select id="project_metadata_license" class="form-control form-control-sm form-control-fixed-width">
                <option value="" {{#unless metadata.license}}selected{{/unless}}>None</option>
                <option value="CC0" {{#is metadata.license "CC0"}}selected{{/is}}>CC0</option>
                <option value="CC_BY_4" {{#is metadata.license "CC_BY_4"}}selected{{/is}}>CC BY 4.0</option>
                <option value="CC_BY_SA_4" {{#is metadata.license "CC_BY_SA_4"}}selected{{/is}}>CC BY-SA 4.0</option>
                <option value="CC_BY_ND_4" {{#is metadata.license "CC_BY_ND_4"}}selected{{/is}}>CC BY-ND 4.0</option>
                <option value="CC_BY_NC_4" {{#is metadata.license "CC_BY_NC_4"}}selected{{/is}}>CC BY-NC 4.0</option>
                <option value="CC_BY_NC_SA_4" {{#is metadata.license "CC_BY_NC_SA_4"}}selected{{/is}}>CC BY-NC-SA 4.0</option>
                <option value="CC_BY_NC_ND_4" {{#is metadata.license "CC_BY_NC_ND_4"}}selected{{/is}}>CC BY-NC-ND 4.0</option>
                <option value="Other" {{#if metadata.license.Other}}selected{{/if}}>Other</option>
            </select>
            <input type="text" id="project_metadata_license_other" class="form-control form-control-sm form-control-fixed-width {{#unless metadata.license.Other}}hide{{/unless}}" placeholder="Specify other license" value="{{metadata.license.Other}}">
        </div>
    </div>
    <div>
        <label>Identifiers</label>
        <div id="project_metadata_identifiers_list">
            {{#each metadata.identifiers}}
                {{> editor_project_metadata_identifier_row}}
            {{/each}}
        </div>
        <label for="project_metadata_identifiers_add_div">Add Identifier</label>
        <div id="project_metadata_identifiers_add_div">
            <div class="project_metadata_identifier_row">
                <select id="project_metadata_identifiers_type">
                    <option value="DOI">DOI</option>
                    <option value="ISBN">ISBN</option>
                    <option value="ISSN">ISSN</option>
                    <option value="URL">URL</option>
                    <option value="URN">URN</option>
                    <option value="ORCID">ORCID</option>
                    <option value="ROR">ROR</option>
                    <option value="GND">GND</option>
                    <option value="Other">Other</option>
                </select>
                <input type="text" class="project_metadata_identifier_other" id="project_metadata_identifiers_other" placeholder="Other type" style="display: none;">
                <input type="text" class="project_metadata_identifier_name" id="project_metadata_identifiers_name" placeholder="Unique Name (e.g. ebook ISBN)">
                <input type="text" class="project_metadata_identifier_value" id="project_metadata_identifiers_value" placeholder="Value (e.g. 10.123456/...)">
                <button class="btn btn-sm btn-primary" id="project_metadata_identifiers_add">Add</button>
            </div>
            <div class="mt-2">

            </div>
        </div>
    </div>
</div>
