<div class="editor-metadata-settings eds-wrap">
    <h2 class="eds-title">Project Settings</h2>
    <div class="eds-form-grid">
        <div class="eds-field eds-field--full eds-checkbox">
            <input type="checkbox" id="set-toc-enabled" {{#if settings.toc_enabled}}checked{{/if}} data-patch="settings.toc_enabled"/>
            <label for="set-toc-enabled">Enable Table of Contents</label>
        </div>

        <div class="eds-field">
            <label class="eds-label" for="set-csl-style">CSL Style</label>
            <select id="set-csl-style" class="eds-select" data-patch="settings.csl_style" data-null-when="None">
                {{#each csl_options}}
                    <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                {{/each}}
            </select>
        </div>

        <div class="eds-field">
            <label class="eds-label" for="set-csl-lang">CSL Language Code</label>
            <input class="eds-input" type="text" id="set-csl-lang" value="{{settings.csl_language_code}}" placeholder="e.g. en-US, de-DE" data-patch="settings.csl_language_code" />
        </div>


        <div class="eds-field">
            <label class="eds-label" for="set-cover-image">Cover Image Path</label>
            <input class="eds-input" type="text" id="set-cover-image" value="{{settings.cover_image_path}}" placeholder="/assets/cover.png" data-patch="settings.cover_image_path" />
        </div>

        <div class="eds-field">
            <label class="eds-label" for="set-backcover-image">Backcover Image Path</label>
            <input class="eds-input" type="text" id="set-backcover-image" value="{{settings.backcover_image_path}}" placeholder="/assets/backcover.png" data-patch="settings.backcover_image_path" />
        </div>

        <div class="eds-field eds-field--full eds-checkbox">
            <input type="checkbox" id="set-add-soft-hyphens" {{#if settings.add_soft_hyphens}}checked{{/if}} data-patch="settings.add_soft_hyphens"/>
            <label for="set-add-soft-hyphens">Auto soft hyphens</label>
        </div>
    </div>

    <h2 class="eds-title eds-title--spaced">Project Metadata</h2>
    <div class="eds-form-grid">
        <div class="eds-field">
            <label class="eds-label" for="md-title">Title</label>
            <input class="eds-input" type="text" id="md-title" value="{{metadata.title}}" data-patch="metadata.title" />
        </div>

        <div class="eds-field">
            <label class="eds-label" for="md-subtitle">Subtitle</label>
            <input class="eds-input" type="text" id="md-subtitle" value="{{metadata.subtitle}}" placeholder="Optional" data-patch="metadata.subtitle" />
        </div>

        <div class="eds-field eds-field--full">
            <label class="eds-label">License</label>
            <div class="license-row eds-row eds-row--gap eds-row--wrap">
                <select id="md-license-select" class="eds-select eds-select--auto" data-patch="metadata.license" data-license="select">
                    {{#each license_options}}
                        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                    {{/each}}
                </select>
                <input class="eds-input eds-input--auto {{#unless license_is_other}}hide{{/unless}}" type="text" id="md-license-other" placeholder="Custom license" value="{{license_other_value}}" data-patch="metadata.licenseOther" data-license="other" />
            </div>
        </div>

        <div class="eds-field eds-field--full identifiers">
            <div class="id-header eds-row eds-row--between eds-row--center">
                <span class="eds-label">Identifiers</span>
                <button id="id-add" type="button" class="eds-button eds-button--secondary eds-button--small">+ Add</button>
            </div>
            <div id="id-list">
                {{> editor_project_metadata_settings_identifiers identifiers_ctx}}
            </div>
        </div>

        <div class="eds-field eds-field--full">
            <label class="eds-label" for="md-tags-free">Tags</label>
            <div class="eds-tags">
                <div id="md-tags-list" class="eds-tags__list"><!-- chips injected here --></div>
                <div class="eds-tags__controls">
                    <div class="eds-row eds-row--gap eds-row--wrap">
                        <input class="eds-input eds-input--auto" type="text" id="md-tags-free" placeholder="Add free tag and press Enter" />
                        <div class="eds-tags__gnd">
                            <input class="eds-input eds-input--auto" type="text" id="md-tags-gnd" placeholder="Search GND…" autocomplete="off" />
                            <div id="md-tags-gnd-suggest" class="eds-suggest hide"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Additional Fields -->
    <div id="active-additional-fields" class="eds-form-grid eds-form-grid--spaced">
        {{#each active_additional_fields}}
        <div class="eds-field eds-field--with-remove {{#is this.type 'textarea'}}eds-field--full{{/is}}">
            <div class="eds-row eds-row--between eds-row--center">
                <label class="eds-label">{{this.label}}</label>
                <button type="button" class="eds-field__remove eds-button eds-button--small eds-button--danger" data-remove-field="{{this.key}}">&times;</button>
            </div>
            {{#is this.type 'textarea'}}
            <textarea class="eds-textarea" data-additional-field="{{this.key}}" data-patch="metadata.{{this.key}}">{{this.value}}</textarea>
            {{else}}
                {{#is this.type 'number'}}
                <input class="eds-input" type="number" data-additional-field="{{this.key}}" data-patch="metadata.{{this.key}}" value="{{this.value}}" />
                {{else}}
                    {{#is this.type 'date'}}
                    <input class="eds-input" type="date" data-additional-field="{{this.key}}" data-patch="metadata.{{this.key}}" value="{{this.value}}" />
                    {{else}}
                    <input class="eds-input" type="text" data-additional-field="{{this.key}}" data-patch="metadata.{{this.key}}" value="{{this.value}}" />
                    {{/is}}
                {{/is}}
            {{/is}}
        </div>
        {{/each}}
    </div>

    <!-- Custom Fields -->
    {{#if custom_fields.length}}
    <h3 class="eds-subtitle eds-subtitle--spaced">Custom Fields</h3>
    {{/if}}
    <div id="custom-fields-list" class="eds-form-grid">
        {{#each custom_fields}}
        <div class="eds-field eds-field--with-remove">
            <div class="eds-row eds-row--between eds-row--center">
                <label class="eds-label">{{this.key}}</label>
                <button type="button" class="eds-field__remove eds-button eds-button--small eds-button--danger" data-remove-custom="{{this.key}}">&times;</button>
            </div>
            <input class="eds-input" type="text" data-custom-field="{{this.key}}" value="{{this.value}}" />
        </div>
        {{/each}}
    </div>

    <!-- Add Field UI -->
    <div class="addable-fields">
        <h3 class="eds-subtitle">Add Additional Field</h3>
        <div class="eds-add-field">
            <div class="eds-add-field__search">
                <input class="eds-input" type="text" id="add-field-search" placeholder="Search or type to create custom field..." autocomplete="off" />
                <div id="add-field-suggest" class="eds-suggest hide"></div>
            </div>
            <button id="add-custom-field" type="button" class="eds-button eds-button--secondary">+ Custom Field</button>
        </div>
        {{#if available_additional_fields.length}}
        <div class="eds-available-fields">
            <span class="eds-available-fields__label">Available:</span>
            <div class="eds-available-fields__list">
                {{#each available_additional_fields}}
                <span class="eds-available-field" data-add-available="{{this.key}}">{{this.label}}</span>
                {{/each}}
            </div>
        </div>
        {{/if}}
    </div>
</div>
