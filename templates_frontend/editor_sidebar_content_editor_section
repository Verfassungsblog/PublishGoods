<div class="sidebar-contents-section" data-section-id="{{id}}">
    <div class="sidebar-contents-section-body" draggable="true">
        <span class="section-title">{{#if metadata.title}}{{metadata.title}}{{else}}[No title]{{/if}}</span>
    </div>
    <div class="sidebar-contents-section-as-child" data-dropzone="as-child"></div>
    <div class="sidebar-contents-section-children">
        {{#each sub_sections}}
            {{> editor_sidebar_content_editor_section this}}
        {{/each}}
    </div>
    <div class="sidebar-contents-section-after" data-dropzone="after"></div>
</div>