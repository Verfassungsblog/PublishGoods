<div class="sidebar-contents-section bibliography-node {{#if is_folder}}is-folder{{else}}is-entry{{/if}}" data-id="{{id}}" draggable="true">
    <div class="sidebar-contents-section-body {{#is id active_id}}active{{/is}}">
        <span class="section-icon">
            {{#if is_folder}}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-folder-fill" viewBox="0 0 16 16">
                    <path d="M9.828 3h3.982a2 2 0 0 1 1.992 2.181l-.637 7A2 2 0 0 1 13.174 14H2.825a2 2 0 0 1-1.991-1.819l-.637-7a2 2 0 0 1 .342-1.31L.5 3a2 2 0 0 1 2-2h3.672a2 2 0 0 1 1.414.586l.828.828A2 2 0 0 0 9.828 3m-8.322.12C1.72 3.042 1.95 3 2.19 3h5.396l-.707-.707A1 1 0 0 0 6.172 2H2.5a1 1 0 0 0-1 .981z"/>
                </svg>
            {{else}}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-earmark-text" viewBox="0 0 16 16">
                    <path d="M8.5 1.5A1.5 1.5 0 0 1 10 0h4a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h6c.828 0 1.5.672 1.5 1.5M9 2.5V1h4.5a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h6.5z"/>
                </svg>
            {{/if}}
        </span>
        <span class="section-title">{{name}}</span>
    </div>
    {{#if children.length}}
    <div class="sidebar-contents-section-children">
        {{#each children}}
            {{> editor_sidebar_bibliography_node this active_id=../active_id}}
        {{/each}}
    </div>
    {{/if}}
</div>
