<div class="editor_section_view_collapsed_metadata">
    <div class="editor_section_view_collapsed_metadata_inner">
        <h1>{{data.metadata.title}}</h1>
        <h2>{{data.metadata.subtitle}}</h2>
    </div>
    <div class="section_metadata_panel_ctl">
        <button title="Show Section Metadata" class="img-btn" id="section_show_metadata"><svg xmlns="http://www.w3.org/2000/svg" height="36" viewBox="0 -960 960 960" width="36"><path d="M480-344 240-584l56-56 184 184 184-184 56 56-240 240Z"/></svg></button>
    </div>
</div>
<div class="editor_section_view_metadata hide">
    <label>Title</label>
    <h1 contenteditable="true" id="section_metadata_title" class="quickchange">{{data.metadata.title}}</h1>
    <label>Subtitle</label>
    <h2 contenteditable="true" id="section_metadata_subtitle"  class="quickchange">{{data.metadata.subtitle}}</h2>
    <div class="form-group">
        <label for="section_metadata_toc_title_subtitle_override">TOC overwrite</label></label>
        <input type="text" class="form-control form-control-sm quickchange" id="section_metadata_toc_title_subtitle_override" value="{{data.metadata.toc_title_subtitle_override}}">
    </div>
    <div class="form-group">
        <label>Authors</label>
        <div id="section_metadata_authors_div" class="persons_list">
            <div id="section_metadata_authors_first_dropzone" class="first_dropzone">
            </div>
            {{#each data.metadata.authors_expanded}}
            {{> editor_section_authors_li}}
            {{/each}}
        </div>
    </div>
    <div class="m-0 align-items-baseline">
        <input type="text" style="width: 300px;" class="form-control form-control-sm" id="section_metadata_search_authors" placeholder="Add Author">
        <ul class="list-group search_result_list hide" tabindex="0" id="section_metadata_search_authors_results">
        </ul>
    </div>
    <div class="form-group">
        <label>Editors</label>
        <div id="section_metadata_editors_div" class="persons_list">
            <div id="section_metadata_editors_first_dropzone" class="first_dropzone">
            </div>
            {{#each data.metadata.editors_expanded}}
                {{> editor_section_editors_li}}
            {{/each}}
        </div>
    </div>
    <div class="m-0 align-items-baseline">
        <input type="text" style="width: 300px;" class="form-control form-control-sm" id="section_metadata_search_editors" placeholder="Add Editor">
        <ul class="list-group search_result_list hide" tabindex="0" id="section_metadata_search_editors_results">
        </ul>
    </div>
    <div class="form-group">
        <label>Web URL</label>
        <input type="text" class="form-control form-control-sm quickchange" value="{{data.metadata.web_url}}" id="section_metadata_web_url">
    </div>

    <label>Identifiers</label>
    <div id="section_metadata_identifiers_list">
        {{#each data.metadata.identifiers}}
        {{> editor_section_identifier_row}}
        {{/each}}
    </div>
    <div class="row">
    <div class="col col-11 mt-4 mb-4">
            <div class="input-group d-flex" id="section_metadata_identifiers">
                <select class="form-select form-select-sm me-1" id="section_metadata_identifiers_type">
                    <option value="DOI">DOI</option>
                    <option value="URN">URN</option>
                </select>
                <input type="text" class="form-control form-control-sm col-4 me-1" id="section_metadata_identifiers_name" placeholder="Name (e.g. DOI)">
                <input type="text" class="form-control form-control-sm" id="section_metadata_identifiers_value" placeholder="Value (e.g. 10.123456/...)">
            </div>
    </div>
        <div class="col col-1 ps-0">
            <button class="btn btn-sm btn-primary" id="section_metadata_identifiers_add">Add</button>
        </div>
    </div>
